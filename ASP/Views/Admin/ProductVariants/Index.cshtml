@using ASP.BaseCommon
@using ASP.Policies
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@model IEnumerable<ASP.Models.Domains.ProductVariant>

@{
    ViewData["Title"] = "Biến thể sản phẩm";
    Layout = "../Shared/Layout/Admin/_Layout";
}

<style>
    #example1 thead th {
        vertical-align: middle;
        text-align: center;
    }
</style>
<div class="content-wrapper" style="min-height: 422px;">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12 col-sm-12">
                    <div class="row">
                        <div class="col-md-6 col-sm-6">
                            @if ((await AuthorizationService.AuthorizeAsync(User, new DocumentAuth(), PolicyOperations.ASPProductVariantsCreate)).Succeeded)
                            {
                                <a class="btn btn-success add-button" asp-route="admin.productvariants.create"><i class="fas fa-plus-square"></i> Thêm mới</a>
                            }
                        </div>
                        <div class="col-md-6 col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a asp-route="admin.dashboard"><i class="fas fa-home"></i> Home</a></li>
                                <li class="breadcrumb-item active">Biến thể sản phẩm</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-xs-12">
                    <div class="box">
                        <div class="clearfix box-body p-2">
                            <table id="example1" class="table table-bordered table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>Sản phẩm</th>
                                        <th>SKU</th>
                                        <th>Size</th>
                                        <th>Color</th>
                                        <th>Giá</th>
                                        <th>Kho (Stock)</th>
                                        <th>Trạng thái</th>
                                        <th>Tác vụ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int count = 0;
                                    }
                                    @if(Model != null)
                                    {
                                        @foreach (var item in Model)
                                        {
                                            count++;
                                            <tr>
                                                <td class="text-center">@count</td>
                                                <td>@(item.Product != null ? item.Product.ProductName : "N/A")</td>
                                                <td>@item.SKU</td>
                                                <td>@item.Size</td>
                                                <td>@item.Color</td>
                                                <td>@item.Price.ToString("N0")</td>
                                                <td>@item.QuantityVariants</td>
                                                <td>
                                                    @if (item.IsActive)
                                                    {
                                                        <span class="badge badge-success">Kích hoạt</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-danger">Đã khóa</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if ((await AuthorizationService.AuthorizeAsync(User, new DocumentAuth(), PolicyOperations.ASPProductVariantsUpdate)).Succeeded)
                                                    {
                                                        <a asp-route="admin.productvariants.edit" asp-route-id="@item.VariantId" class="badge badge-primary" title="Sửa!"><i class="fas fa-edit"></i> Sửa</a>
                                                    }
                                                    @if ((await AuthorizationService.AuthorizeAsync(User, new DocumentAuth(), PolicyOperations.ASPProductVariantsDelete)).Succeeded)
                                                    {
                                                        <a onclick="return confirm('Bạn muốn Xóa bản ghi này?')" asp-route="admin.productvariants.delete" asp-route-id="@item.VariantId" title="Xóa!" class="badge badge-danger"><i class="fas fa-trash-alt"></i> Xóa</a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script type="text/javascript">
        $(function () {
            // Establish SignalR connection
            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/adminHub")
                .configureLogging(signalR.LogLevel.Information)
                .build();

            // Listen to Create
            connection.on("VariantCreated", function (variant) {
                console.log("Variant created for product: " + variant.productId);
                window.location.reload();
            });

            // Listen to Update
            connection.on("VariantUpdated", function (variant) {
                console.log("Variant updated for product: " + variant.productId);
                window.location.reload();
            });

            // Listen to Delete
            connection.on("VariantDeleted", function (variantId, productId) {
                console.log("Variant deleted: " + variantId + " for product: " + productId);
                window.location.reload();
            });

            connection.start().then(function () {
                console.log("Connected to AdminHub successfully (Product Variants).");
            }).catch(function (err) {
                return console.error("AdminHub connection error: " + err.toString());
            });
        });
    </script>
}
